+async def link_existing_user(
+    db: AsyncSession,
+    user_id: int,
+    kind: IdentityKind,
+    value: str,
+    *,
+    vk_access_token_enc: bytes | None = None,
+    vk_refresh_token_enc: bytes | None = None,
+    vk_token_expires_at: datetime | None = None,
