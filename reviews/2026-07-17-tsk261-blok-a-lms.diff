+@pytest.mark.asyncio
+async def test_api_passes_position_through(db, client, tree):
+    """Проводка эндпоинта: query-параметр after_material_id доходит до движка.
+
+    Юнит-тесты выше зовут сервис напрямую; этот идёт через реальный HTTP-слой —
