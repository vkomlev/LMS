+def _normalize_due_at(due_at: Any) -> Optional[datetime]:
+    """в•ЁРҜв•ӨРҗв•Ёв••в•Ёв–“в•Ёв•ӣв•Ёв”Өв•Ёв••в•ӨР’ due_at в•Ёв••в•Ёв•– в•ӨР‘в•ӨРӣв•ӨРҗв•Ёв•ӣв•Ёв”Ӯв•Ёв•ӣ SQL (str в•Ёв••в•Ёв•—в•Ёв•• datetime) в•Ёв•‘ timezone-aware datetime в•Ёв”Өв•Ёв•—в•ӨРҹ в•ӨР‘в•ӨРҗв•Ёв–‘в•Ёв–“в•Ёв•ңв•Ёв•Ўв•Ёв•ңв•Ёв••в•ӨРҹ в•ӨР‘ now."""
+    if due_at is None:
+        return None
+    if isinstance(due_at, str):
+        s = due_at.strip().replace("Z", "+00:00")
+        try:
+            dt = datetime.fromisoformat(s)
+        except ValueError:
+            return None
+        return dt if dt.tzinfo else dt.replace(tzinfo=timezone.utc)
+    if isinstance(due_at, datetime):
+        return due_at if due_at.tzinfo else due_at.replace(tzinfo=timezone.utc)
+    return None
+
