+                        )
+                        if refreshed:
+                            existing_map[key] = refreshed
+                        result_rows.append(
+                            MaterialsBulkUpsertResultItem(
+                                course_id=cid,
+                                external_uid=ext,
+                                status="updated",
+                                material_id=existing.id,
+                            )
+                        )
+                        updated_n += 1
+                else:
+                    new_m = await self.repo.create(db, payload_data)
+                    existing_map[key] = new_m
+                    result_rows.append(
+                        MaterialsBulkUpsertResultItem(
+                            course_id=cid,
+                            external_uid=ext,
+                            status="created",
+                            material_id=new_m.id,
+                        )
+                    )
+                    created_n += 1
+            except IntegrityError as e:
