+                    f"курсах — ROLLBACK"
+                )
+                await tx.rollback()
+                return 1
+            print("межгрупповой порядок THEORY->EASY->NORMAL->HARD->PROJECT — OK (0 нарушений)")
+
+            gaps = await conn.fetch("""
