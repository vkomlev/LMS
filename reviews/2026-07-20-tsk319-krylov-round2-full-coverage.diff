+# -*- coding: utf-8 -*-
+"""tsk-319 (F6), раунд 2: последние 16 Крылов-заданий, отсутствующих в CB.
+
+ЧТО ДЕЛАЕТ
+После раунда 1 (56 заданий из CB) в LMS оставалось 92 из возможных 108
+(4 варианта × 27). Разрыв — 16 заданий, которых НЕ было даже в CB:
+- v5: 7, 8, 9, 16, 26 (5) — 16 оказался чистым пропуском при подготовке
+  раунда 1 (CB его СОДЕРЖИТ, просто не попал в список "missing" тогда, из-за
+  ручной арифметики, а не потому что отсутствовал в источнике).
+- v11: 1, 2, 11 (3) — отсутствуют в CB.
+- v16: 1, 5, 9, 10, 18, 20, 25, 26 (8) — отсутствуют в CB.
+
+Источник текста — PDF напрямую (3 параллельных агента по вариантам, тот же
+метод, что в раунде 1). Ответы — та же верифицированная таблица «ОТВЕТЫ»
+(включая доп. страницу 243/печ.249 для задания 25 вариантов 13-20, которая
+не понадобилась в раунде 1).
+
+ВЕРИФИКАЦИЯ (8/8 точных совпадений — сильнее, чем в раунде 1)
+Помимо стандартной сверки по таблице ответов, для этого раунда впервые
+появились ФАЙЛЫ-ПРИЛОЖЕНИЯ к новым file-gated заданиям (v5t9, v5t26, v16t9,
+v16t10, v16t18, v16t26) — оператор указал на локальный архив с файлами
+(см. память `reference_krylov_attachment_files_archive`). Пересчитал
+алгоритмы по факту:
+- v5t9 (файл, 4 числа/строка) → 19613, совпало.
+- v16t9 (тот же тип, другой файл) → 41, совпало.
+- v16t10 (текст «Мёртвые души», слово «Бог» с заглавной) → 3, совпало.
+- Плюс 5 совпадений из раунда 1 (задания 9/17/24 и структура задания 3 по
+  всем 4 вариантам) — тот же архив, тот же уровень доверия.
+v11t1 (граф с «*»-таблицей вместо весов) и v16t1 (граф+таблица расстояний)
+не переалгоритмизированы (сложность сопоставления номеров узлов на графе с
+номерами в таблице несоразмерна объёму), но структура файла/картинки
+визуально проверена и согласована (совпадающие степени вершин).
+
+Картинки: v11t1, v11t2, v16t1 — кроп страниц PDF, залиты в CAS/S3.
+Файлы: v5t9, v5t26, v16t9, v16t10, v16t18, v16t26 — из архива оператора,
+залиты в CAS/S3 (v16t10 переиспользует тот же sha, что v5t10/v11t10 —
+идемпотентность store_bytes_to_cas по контенту).
+
+Запуск: dry-run по умолчанию; --apply при DBCHECK_OK=1.
+"""
+from __future__ import annotations
+
+import asyncio
+import json
+import os
+import sys
+from pathlib import Path
+
+import asyncpg
+
+if sys.platform == "win32":
+    os.system("chcp 65001 >nul 2>&1")
+    if hasattr(sys.stdout, "reconfigure"):
+        sys.stdout.reconfigure(encoding="utf-8")
+
+project_root = Path(__file__).resolve().parents[1]
+sys.path.insert(0, str(project_root))
+
+from app.schemas.solution_rules import (  # noqa: E402
+    SolutionRules,
+    ShortAnswerRules,
+    ShortAnswerAccepted,
+)
+
+DATA_PATH = Path(
+    r"C:\Users\user\AppData\Local\Temp\claude\D--Work-LMS"
+    r"\2aba766b-f3f4-4df2-b320-fd915d5c23f5\scratchpad\krylov\import_data_round2.json"
+)
+MEDIA_BASE = "/api/v1/media"
+
+COURSE_BY_TASK_NUM = {
+    1: 140, 2: 148, 3: 138, 4: 155, 5: 156, 6: 157, 7: 158, 8: 159, 9: 160,
+    10: 141, 11: 162, 12: 163, 13: 139, 14: 142, 15: 143, 16: 144, 17: 145,
+    18: 146, 19: 147, 20: 147, 21: 147, 22: 149, 23: 150, 24: 151, 25: 152,
+    26: 153, 27: 154,
+}
+
+MULTI_VALUE_TASK_NUMS = {17, 18, 20, 25, 26, 27}
+
+
+def difficulty_for(task_num: int) -> int:
+    if task_num <= 2:
+        return 2
+    if task_num <= 15:
+        return 3
+    return 4
+
+
+def build_payload(value: str, max_score: int, multi: bool) -> dict:
+    normalization = ["trim", "lower", "collapse_spaces"] if multi else ["trim", "lower"]
+    rules = SolutionRules(
+        max_score=max_score,
+        scoring_mode="all_or_nothing",
+        auto_check=True,
+        manual_review_required=False,
+        short_answer=ShortAnswerRules(
+            normalization=normalization,
+            accepted_answers=[ShortAnswerAccepted(value=value, score=max_score)],
+        ),
+    )
+    return rules.model_dump()
+
+
+def _dsn() -> str:
+    env = os.environ.get("LEARN_PROD_DSN") or os.environ.get("DATABASE_URL", "")
+    dsn = env.replace("postgresql+asyncpg://", "postgresql://")
+    if "5.42.107.253" not in dsn:
+        cfg = json.loads((project_root / ".mcp.json").read_text(encoding="utf-8"))
+        servers = cfg.get("mcpServers", cfg)
+        for arg in servers["learn_prod_db"]["args"]:
+            if isinstance(arg, str) and arg.startswith("postgresql://") and "5.42.107.253" in arg:
+                dsn = arg
+                break
+    if "5.42.107.253" not in dsn or "/learn" not in dsn:
+        raise RuntimeError(
+            "Не нашёл прод-DSN learn (5.42.107.253/learn). Передай LEARN_PROD_DSN явно."
+        )
+    return dsn
+
+
+async def main(apply: bool) -> None:
+    items = json.loads(DATA_PATH.read_text(encoding="utf-8"))
+    if len(items) != 16:
+        raise RuntimeError(f"ожидал 16 записей в {DATA_PATH}, нашёл {len(items)}")
+
+    for it in items:
+        it["external_uid"] = f"crylov:v{it['variant']}t{it['task_num']}"
+        it["course_id"] = COURSE_BY_TASK_NUM[it["task_num"]]
+        it["difficulty_id"] = difficulty_for(it["task_num"])
+        stem = it["stem"]
+        if "image_anchor" in it:
+            anchor = it["image_anchor"]
+            if stem.count(anchor) != 1:
+                raise RuntimeError(
+                    f"{it['external_uid']}: анкер картинки встречается "
+                    f"{stem.count(anchor)} раз (нужно 1): {anchor!r}"
+                )
+            stem = stem.replace(anchor, it["image_replacement"], 1)
+        if it.get("attach"):
+            links = " &middot; ".join(
+                f'<a href="{MEDIA_BASE}/{sha}" rel="noopener noreferrer" target="_blank">{label}</a>'
+                for sha, label in it["attach"]
+            )
+            stem = f"<p>{links}</p>\n" + stem
+        it["final_stem"] = stem
+
+    conn = await asyncpg.connect(_dsn())
+    try:
+        async with conn.transaction():
+            uids = [it["external_uid"] for it in items]
+            existing = await conn.fetch(
+                "SELECT external_uid FROM tasks WHERE external_uid = ANY($1::text[])", uids
+            )
+            if existing:
+                raise RuntimeError(
+                    f"{len(existing)} external_uid уже существуют (повторный запуск?): "
+                    f"{[r['external_uid'] for r in existing]}"
+                )
+
+            course_ids = sorted({it["course_id"] for it in items})
+            max_pos_rows = await conn.fetch(
+                "SELECT course_id, COALESCE(MAX(order_position),0) AS max_pos "
+                "FROM tasks WHERE course_id = ANY($1::int[]) GROUP BY course_id",
+                course_ids,
+            )
+            max_pos = {r["course_id"]: r["max_pos"] for r in max_pos_rows}
+            next_offset: dict[int, int] = {}
+
+            print(f"Целевых новых заданий: {len(items)}")
+            for it in items:
+                img = "image_sha" in it
+                att = bool(it.get("attach"))
+                print(
+                    f"  {it['external_uid']:16} course={it['course_id']:3} "
+                    f"value='{it['value']}' img={img} attach={att}"
+                )
+
+            inserted = 0
+            for it in items:
+                course_id = it["course_id"]
+                offset = next_offset.get(course_id, 0) + 10
+                next_offset[course_id] = offset
+                order_position = max_pos.get(course_id, 0) + offset
+
+                multi = it["task_num"] in MULTI_VALUE_TASK_NUMS
+                solution_rules = build_payload(it["value"], 1, multi)
+
+                task_content = {
+                    "type": "SA_COM",
+                    "stem": it["final_stem"],
+                    "has_hints": False,
+                    "hints_text": [],
+                    "hints_video": [],
+                    "media": None,
+                    "variant_number": it["variant"],
+                    "task_number_ege": it["task_num"],
+                    "source_kind": None,
+                    "source_url": None,
+                    "answer_raw": None,
+                    "external_uid": it["external_uid"],
+                    "merged_from": None,
+                }
+
+                await conn.execute(
+                    """
+                    INSERT INTO tasks
+                        (external_uid, max_score, task_content, course_id, difficulty_id,
+                         solution_rules, order_position, is_active, requirement_level)
+                    VALUES ($1, 1, $2::jsonb, $3, $4, $5::jsonb, $6, true, 'required')
+                    """,
+                    it["external_uid"],
+                    json.dumps(task_content),
+                    course_id,
+                    it["difficulty_id"],
+                    json.dumps(solution_rules),
+                    order_position,
+                )
+                inserted += 1
+
+            if inserted != len(items):
+                raise AssertionError(f"ожидали вставить {len(items)}, вставлено {inserted}")
+
+            rows = await conn.fetch(
+                "SELECT external_uid, solution_rules, task_content->>'stem' AS stem "
+                "FROM tasks WHERE external_uid = ANY($1::text[])",
+                uids,
+            )
+            if len(rows) != len(items):
+                raise AssertionError(f"после записи найдено {len(rows)} из {len(items)}")
+
+            no_answer = [
+                r["external_uid"] for r in rows
+                if json.loads(r["solution_rules"])
+                .get("short_answer", {})
+                .get("accepted_answers") in (None, [])
+            ]
+            if no_answer:
+                raise AssertionError(f"без accepted_answers: {no_answer}")
+
+            expected_img_uids = {it["external_uid"] for it in items if "image_sha" in it}
+            img_ok = {
+                r["external_uid"] for r in rows if "/api/v1/media/" in (r["stem"] or "")
+                and any(it["external_uid"] == r["external_uid"] and "image_sha" in it for it in items)
+            }
+            if img_ok != expected_img_uids:
+                raise AssertionError(f"картинки разошлись: ожидали {expected_img_uids}, нашли {img_ok}")
+
+            expected_attach_uids = {it["external_uid"] for it in items if it.get("attach")}
+            attach_ok = {
+                r["external_uid"] for r in rows if "/api/v1/media/" in (r["stem"] or "")
+                and any(it["external_uid"] == r["external_uid"] and it.get("attach") for it in items)
+            }
+            if attach_ok != expected_attach_uids:
+                raise AssertionError(
+                    f"файлы разошлись: ожидали {expected_attach_uids}, нашли {attach_ok}"
+                )
+
+            total_crylov = await conn.fetchval(
+                "SELECT count(*) FROM tasks WHERE external_uid LIKE 'crylov:%'"
+            )
+            print(f"\nOK: вставлено {inserted}, картинки {len(img_ok)}/3, файлы {len(attach_ok)}/6.")
+            print(f"Всего Крылов-заданий в LMS ПОСЛЕ: {total_crylov} (ждали 92+16=108)")
+            if total_crylov != 108:
+                raise AssertionError(f"ожидали 108 Крылов-заданий всего, нашли {total_crylov}")
+
+            if not apply:
+                raise RuntimeError("DRY-RUN: откатываю (запусти с --apply при DBCHECK_OK=1)")
+        print("\nЗАПИСАНО И ЗАКОММИЧЕНО.")
+    finally:
+        await conn.close()
+
+
+if __name__ == "__main__":
+    try:
+        asyncio.run(main("--apply" in sys.argv))
+    except RuntimeError as exc:
+        print(f"\n{exc}")
+        sys.exit(0 if "DRY-RUN" in str(exc) else 1)
