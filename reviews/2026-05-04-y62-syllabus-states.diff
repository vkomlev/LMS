+async def _find_item(items: list[dict], *, kind: str, id_key: str, target_id: int):
+    """в•ЁРЁв•ӨРҷв•Ёв•Ўв•ӨР’ item в•Ёв–“ response.items в•Ёв”җв•Ёв•ӣ (kind, id_key=target_id)."""
+    for it in items:
+        if it.get("kind") == kind and it.get(id_key) == target_id:
+            return it
+    return None
+
