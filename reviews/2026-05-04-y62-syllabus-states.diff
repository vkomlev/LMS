+WHERE cd.course_id = ANY(:tree_ids)
+  AND NOT EXISTS (
+      SELECT 1 FROM student_course_state scs
+      WHERE scs.student_id = :user_id
+        AND scs.course_id = cd.required_course_id
+        AND scs.state = 'COMPLETED'
+  )
+"""
+
+
+def _compute_syllabus_task_status(row: dict) -> str:
+    """в•ЁР¬в•Ёв–‘в•Ёв”җв•Ёв”җв•Ёв••в•Ёв•ңв•Ёв”Ӯ last task_result + attempts СӮР–Рў public-status в•ӨР‘в•ӨР’в•ӨРҗв•Ёв•ӣв•Ёв•‘в•Ёв–‘.
+
+    в•ЁРҜв•ӨРҗв•Ёв–‘в•Ёв–“в•Ёв••в•Ёв•—в•Ёв–‘ (в•ӨР‘в•Ёв•қ. tech-spec syllabus-states):
+    - passed         СӮРҗРӨ last is_correct=TRUE, checked_at NOT NULL
+    - pending_review СӮРҗРӨ last is_correct=TRUE, checked_at IS NULL (Y-6 optimistic);
+                       в•ӨР’в•Ёв–‘в•Ёв•‘в•Ёв•ўв•Ёв•Ў legacy IS NULL pending (pre-Y-6 SA_COM/TA)
+    - failed         СӮРҗРӨ last is_correct=FALSE в•Ёв•• attempts_used < limit
+    - blocked_limit  СӮРҗРӨ last is_correct=FALSE в•Ёв•• attempts_used >= limit
+    - in_progress    СӮРҗРӨ в•Ёв•ңв•Ёв•Ўв•ӨР’ task_result, в•Ёв•ңв•Ёв•ӣ в•Ёв•Ўв•ӨР‘в•ӨР’в•ӨРң в•Ёв•ӣв•ӨР’в•Ёв•‘в•ӨРҗв•ӨРӣв•ӨР’в•ӨРӣв•Ёв•Ј course-level attempt
+    - not_started    СӮРҗРӨ в•Ёв•ңв•Ёв•Ўв•ӨР’ task_result в•Ёв•• в•Ёв•ңв•Ёв•Ўв•ӨР’ в•Ёв•ӣв•ӨР’в•Ёв•‘в•ӨРҗв•ӨРӣв•ӨР’в•Ёв•ӣв•Ёв”Ӯв•Ёв•ӣ attempt
+    """
+    last_submitted = row["last_submitted_at"]
+    is_correct = row["last_is_correct"]
+    checked_at = row["last_checked_at"]
+    attempts_used = int(row["attempts_used"] or 0)
+    limit_eff = int(row["attempts_limit_effective"] or 0)
+    has_open = bool(row["has_open_attempt"])
+
+    if last_submitted is None:
+        return "in_progress" if has_open else "not_started"
+
+    if is_correct is True:
+        return "passed" if checked_at is not None else "pending_review"
+    if is_correct is None:
+        # legacy pre-Y-6 pending state (TA/SA_COM в•Ёв”Өв•Ёв•ӣ optimistic-PASSED backfill)
+        return "pending_review"
+    # is_correct is False
+    if limit_eff > 0 and attempts_used >= limit_eff:
+        return "blocked_limit"
+    return "failed"
+
+
+async def get_syllabus_states(
+    db: AsyncSession,
+    user_id: int,
+    root_course_id: int,
+) -> dict:
+    """в•ЁРұв•Ёв•ңв•Ёв••в•Ёв•қв•Ёв•ӣв•Ёв•‘ в•ӨР‘в•Ёв•ӣв•ӨР‘в•ӨР’в•Ёв•ӣв•ӨРҹв•Ёв•ңв•Ёв••в•Ёв•Ј в•Ёв•–в•Ёв–‘в•Ёв”Өв•Ёв–‘в•ӨР—+в•Ёв•қв•Ёв–‘в•ӨР’в•Ёв•Ўв•ӨРҗв•Ёв••в•Ёв–‘в•Ёв•—в•Ёв•ӣв•Ёв–“ в•Ёв”җв•Ёв•ӣв•Ёв”Өв•Ёв”Өв•Ёв•Ўв•ӨРҗв•Ёв•Ўв•Ёв–“в•Ёв–‘ в•Ёв•‘в•ӨР“в•ӨРҗв•ӨР‘в•Ёв–‘ в•Ёв”Өв•Ёв•—в•ӨРҹ SPW syllabus-в•ӨРҗв•Ёв•Ўв•Ёв•ңв•Ёв”Өв•Ёв•Ўв•ӨРҗв•Ёв–‘.
+
+    Phase Y-6.2. Single SQL roundtrip per resource (tasks/materials/blocked):
+    - tree_ids СӮРҗРӨ depth-first traversal в•ӨР—в•Ёв•Ўв•ӨРҗв•Ёв•Ўв•Ёв•– LearningEngineService
+      (в•ӨР“в•ӨР—в•Ёв••в•ӨР’в•ӨРӣв•Ёв–“в•Ёв–‘в•Ёв•Ўв•ӨР’ course_parents.order_number)
+    - per-task status СӮРҗРӨ в•Ёв”җв•Ёв•ӣв•ӨР‘в•Ёв•—в•Ёв•Ўв•Ёв”Өв•Ёв•ңв•Ёв••в•Ёв•Ј task_result в”ңР§ attempts_used в”ңР§ override
+    - per-material status СӮРҗРӨ student_material_progress.status='completed'
+    - blocked_courses СӮРҗРӨ course_dependencies в•Ёв–’в•Ёв•Ўв•Ёв•– COMPLETED prerequisite
+      в•Ёв–“ `student_course_state` в•Ёв”җв•Ёв•ӣв•Ёв•—в•ӨРңв•Ёв•–в•Ёв•ӣв•Ёв–“в•Ёв–‘в•ӨР’в•Ёв•Ўв•Ёв•—в•ӨРҹ.
+
+    Items emit'в•ӨРҹв•ӨР’в•ӨР‘в•ӨРҹ: в•Ёв”Өв•Ёв•—в•ӨРҹ в•Ёв•‘в•Ёв–‘в•Ёв•ўв•Ёв”Өв•Ёв•ӣв•Ёв”Ӯв•Ёв•ӣ course в•Ёв–“ depth-first order СӮРҗРӨ в•Ёв•қв•Ёв–‘в•ӨР’в•Ёв•Ўв•ӨРҗв•Ёв••в•Ёв–‘в•Ёв•—в•ӨРӣ
+    (в•Ёв”җв•Ёв•ӣ order_position), в•Ёв•–в•Ёв–‘в•ӨР’в•Ёв•Ўв•Ёв•қ в•Ёв•–в•Ёв–‘в•Ёв”Өв•Ёв–‘в•Ёв•ңв•Ёв••в•ӨРҹ (в•Ёв”җв•Ёв•ӣ id) СӮРҗРӨ в•Ёв”җв•Ёв–‘в•ӨРҗв•Ёв••в•ӨР’в•Ёв•Ўв•ӨР’ в•ӨР‘
+    `_first_incomplete_material` / `_first_incomplete_task` в•Ёв–“ learning engine.
+
+    Args:
+        db: async session.
+        user_id: ID в•ӨР‘в•ӨР’в•ӨР“в•Ёв”Өв•Ёв•Ўв•Ёв•ңв•ӨР’в•Ёв–‘.
+        root_course_id: ID в•Ёв•‘в•Ёв•ӣв•ӨРҗв•Ёв•ңв•Ёв•Ўв•Ёв–“в•Ёв•ӣв•Ёв”Ӯв•Ёв•ӣ course (в•Ёв•—в•ӨРһв•Ёв–’в•Ёв•ӣв•Ёв•Ј в•ӨР“в•Ёв•–в•Ёв•Ўв•Ёв•— в•Ёв”Өв•Ёв•Ўв•ӨРҗв•Ёв•Ўв•Ёв–“в•Ёв–‘).
+
+    Returns:
+        dict {course_id, items, blocked_courses}.
+    """
+    # в•ЁРЁв•Ёв•қв•Ёв”җв•Ёв•ӣв•ӨРҗв•ӨР’ inline в•Ёв–“в•Ёв•ӣ в•Ёв••в•Ёв•–в•Ёв–’в•Ёв•Ўв•Ёв•ўв•Ёв–‘в•Ёв•ңв•Ёв••в•Ёв•Ў circular import (engine СӮР–Рў repos СӮР–Рў ...)
+    from app.services.learning_engine_service import (
+        DEFAULT_MAX_ATTEMPTS,
+        LearningEngineService,
+    )
+
+    engine = LearningEngineService()
+    tree_ids: list[int] = await engine._collect_courses_in_order(db, root_course_id)
+    if not tree_ids:
+        tree_ids = [root_course_id]
+
+    tasks_res = await db.execute(
+        text(_SYLLABUS_TASKS_SQL),
+        {
+            "user_id": user_id,
+            "tree_ids": tree_ids,
+            "default_max": DEFAULT_MAX_ATTEMPTS,
+        },
+    )
+    task_rows = tasks_res.mappings().all()
+
+    materials_res = await db.execute(
+        text(_SYLLABUS_MATERIALS_SQL),
+        {"user_id": user_id, "tree_ids": tree_ids},
+    )
+    material_rows = materials_res.mappings().all()
+
+    blocked_res = await db.execute(
+        text(_BLOCKED_COURSES_SQL),
+        {"user_id": user_id, "tree_ids": tree_ids},
+    )
+    blocked_courses: list[int] = [int(r[0]) for r in blocked_res.fetchall()]
+
+    # в•ЁРЈв•ӨРҗв•ӨР“в•Ёв”җв•Ёв”җв•Ёв••в•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв•‘в•Ёв–‘ в•Ёв”җв•Ёв•ӣ course_id в•Ёв”Өв•Ёв•—в•ӨРҹ depth-first emit
+    materials_by_course: dict[int, list[dict]] = {}
+    for r in material_rows:
+        materials_by_course.setdefault(r["course_id"], []).append(dict(r))
+    tasks_by_course: dict[int, list[dict]] = {}
+    for r in task_rows:
+        tasks_by_course.setdefault(r["course_id"], []).append(dict(r))
+
+    items: list[dict] = []
+    for cid in tree_ids:
+        for m in materials_by_course.get(cid, []):
+            items.append(
+                {
+                    "kind": "material",
+                    "material_id": int(m["material_id"]),
+                    "course_id": int(m["course_id"]),
+                    "status": "completed" if m["completed_at"] is not None else "not_started",
+                    "completed_at": m["completed_at"],
+                }
+            )
+        for t in tasks_by_course.get(cid, []):
+            items.append(
+                {
+                    "kind": "task",
+                    "task_id": int(t["task_id"]),
+                    "course_id": int(t["course_id"]),
+                    "status": _compute_syllabus_task_status(t),
+                    "attempts_used": int(t["attempts_used"] or 0),
+                    "attempts_limit_effective": int(t["attempts_limit_effective"] or 0),
+                    "last_score": int(t["last_score"]) if t["last_score"] is not None else None,
+                    "last_max_score": (
+                        int(t["last_max_score"]) if t["last_max_score"] is not None else None
+                    ),
+                    "last_submitted_at": t["last_submitted_at"],
+                }
+            )
+
+    return {
+        "course_id": root_course_id,
+        "items": items,
+        "blocked_courses": blocked_courses,
+    }
+
+
 async def get_history(
     db: AsyncSession,
     user_id: int,
