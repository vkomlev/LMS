+        cwd=str(project_root),
+        capture_output=True,
+        text=True,
+        encoding="utf-8",
+        errors="replace",
+    )
+    assert seed.returncode == 0, f"seed_roles на тестовой БД не прошёл:\n{seed.stderr}"
+
+    yield test_dsn
+
+    os.environ["DATABASE_URL"] = previous
