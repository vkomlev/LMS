+            print(f"–Ь–∞—А—И—А—Г—В: auto (accepted_answers) = {by_route['auto']}, "
+                  f"manual (—А—Г—З–љ–∞—П –њ—А–Њ–≤–µ—А–Ї–∞) = {by_route['manual']}")
+            print(f"–Я–Њ –Є—Б—В–Њ—З–љ–Є–Ї–∞–Љ: {by_src}")
+            print("\n–Я—А–Є–Љ–µ—А—Л –і–Њ/–њ–Њ—Б–ї–µ (answer_raw вЖТ –Љ–∞—А—И—А—Г—В вЖТ accepted):")
+            for tid, src, route, raw, accepted in samples[:25]:
+                after = f"accepted='{accepted}'" if route == "auto" else "manual_review_required=true"
+                print(f"  [{route:6}] id={tid} {src:8} '{raw}' вЖТ {after}")
+
+            target_ids = list(payloads.keys())
+            null_before = await conn.fetchval(
+                "SELECT count(*) FROM tasks WHERE is_active "
+                "AND (solution_rules IS NULL OR jsonb_typeof(solution_rules)='null')"
+            )
+            print(f"\n–Т—Б–µ–≥–Њ –Ј–∞–і–∞–љ–Є–є —Б solution_rules=null –Ф–Ю: {null_before}")
+
+            updated = 0
+            for tid, pj in payloads.items():
+                res = await conn.execute(UPDATE_ONE, tid, pj)
+                # res –≤–Є–і–∞ 'UPDATE 1'
+                updated += int(res.split()[-1])
+
+            # ---- –Т–µ—А–Є—Д–Є–Ї–∞—Ж–Є—П –≤–љ—Г—В—А–Є —В—А–∞–љ–Ј–∞–Ї—Ж–Є–Є (–љ–µ–Ј–∞–≤–Є—Б–Є–Љ—Л–Љ —З—В–µ–љ–Є–µ–Љ) ----
+            if updated != total:
+                raise AssertionError(f"–Њ–ґ–Є–і–∞–ї–Є –Њ–±–љ–Њ–≤–Є—В—М {total}, –Њ–±–љ–Њ–≤–ї–µ–љ–Њ {updated}")
+
+            still_null_in_targets = await conn.fetchval(
+                "SELECT count(*) FROM tasks WHERE id = ANY($1::int[]) "
+                "AND (solution_rules IS NULL OR jsonb_typeof(solution_rules)='null')",
+                target_ids,
+            )
+            if still_null_in_targets != 0:
+                raise AssertionError(f"–њ–Њ—Б–ї–µ –Ј–∞–њ–Є—Б–Є –Њ—Б—В–∞–ї–Є—Б—М null –≤ –≤—Л–±–Њ—А–Ї–µ: {still_null_in_targets}")
+
+            null_after = await conn.fetchval(
+                "SELECT count(warning: in the working copy of 'tests/test_attempts_null_solution_rules_tsk325.py', LF will be replaced by CRLF the next time Git touches it
*) FROM tasks WHERE is_active "
+                "AND (solution_rules IS NULL OR jsonb_typeof(solution_rules)='null')"
+            )
+            print(f"–Т—Б–µ–≥–Њ –Ј–∞–і–∞–љ–Є–є —Б solution_rules=null –Я–Ю–°–Ы–Х: {null_after} "
+                  f"(—Б–љ–Є–ґ–µ–љ–Є–µ –љ–∞ {null_before - null_after})")
+            if null_before - null_after != total:
+                raise AssertionError(
+                    f"—Б–љ–Є–ґ–µ–љ–Є–µ null ({null_before - null_after}) != —З–Є—Б–ї—Г —Ж–µ–ї–µ–є ({total}) вАФ "
+                    "–Ј–∞–і–µ—В—Л –Ј–∞–і–∞–љ–Є—П –≤–љ–µ –≤—Л–±–Њ—А–Ї–Є?"
+                )
+
+            # accepted_answers —А–µ–∞–ї—М–љ–Њ –њ—А–Њ—Б—В–∞–≤–ї–µ–љ—Л —Г auto-–Ј–∞–і–∞–љ–Є–є.
+            auto_ok = await conn.fetchval(
+                "SELECT count(*) FROM tasks WHERE id = ANY($1::int[]) "
+                "AND jsonb_array_length(COALESCE(solution_rules#>'{short_answer,accepted_answers}','[]'::jsonb)) = 1",
+                target_ids,
+            )
+            manual_ok = await conn.fetchval(
+                "SELECT count(*) FROM tasks WHERE id = ANY($1::int[]) "
+                "AND (solution_rules->>'manual_review_required')::bool IS TRUE "
+                # short_answer —Г —А—Г—З–љ—Л—Е –Ј–∞–і–∞–љ–Є–є вАФ JSON null (–љ–µ SQL NULL): –Ї–ї—О—З –µ—Б—В—М,
+                # –Ј–љ–∞—З–µ–љ–Є–µ null. SQL `IS NULL` –і–ї—П JSON-null –ї–Њ–ґ–љ–Њ, –њ—А–Њ–≤–µ—А—П–µ–Љ typeof.
+                "AND jsonb_typeof(solution_rules->'short_answer') = 'null'",
+                target_ids,
+            )
+            print(f"–Я—А–Њ–≤–µ—А–Ї–∞: auto —Б 1 accepted = {auto_ok} (–ґ–і—С–Љ {by_route['auto']}); "
+                  f"manual –±–µ–Ј short_answer = {manual_ok} (–ґ–і—С–Љ {by_route['manual']})")
+            if auto_ok != by_route["auto"]:
+                raise AssertionError(f"auto accepted mismatch: {auto_ok} != {by_route['auto']}")
+            if manual_ok != by_route["manual"]:
+                raise AssertionError(f"manual mismatch: {manual_ok} != {by_route['manual']}")
+
+            # max_score –њ—А–∞–≤–Є–ї–∞ —Б–Њ–≤–њ–∞–і–∞–µ—В —Б tasks.max_score —Г –≤—Б–µ—Е —Ж–µ–ї–µ–є.
+            ms_mismatch = await conn.fetchval(
+                "SELECT count(*) FROM tasks WHERE id = ANY($1::int[]) "
+                "AND (solution_rules->>'max_score')::int IS DISTINCT FROM max_score",
+                target_ids,
