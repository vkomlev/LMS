@@ -0,0 +1,174 @@
+"""tsk-398 — тесты нормализатора математической разметки stem.
+
+Покрывают три класса дефекта импорта заданий ЕГЭ (follow-up tsk-391):
+  - B: KaTeX-вёрстка чужого сайта → `$LaTeX$` из <annotation>;
+  - C: суррогатная степень `**`/`^` → <sup> (код защищён);
+  - D: сырой `<`/`>` в извлечённом LaTeX → `\\lt`/`\\gt` (HTML-безопасно).
+
+Образец katex — реальный stem задания 2949 (прод `learn`, партия ext:d4),
+класс B из инвентаря tsk-391.
+"""
+from __future__ import annotations
+
+import sys
+from pathlib import Path
+
+_root = Path(__file__).resolve().parent.parent
+if str(_root) not in sys.path:
+    sys.path.insert(0, str(_root))
+
+from monolith.external_tasks.normalizer.katex_latex import (
+    katex_html_to_latex,
+    normalize_math_markup,
+    surrogate_powers_to_sup,
+)
+
+# Реальный katex-блок из прод-stem задания 2949 (усечён после annotation —
+# для проверки достаточно, границы блока считаются балансом span-тегов).
+_REAL_KATEX = (
+    '<p>Операнды записаны в системе счисления с основанием 19.<br/>'
+    '<span><span class="katex"><span class="katex-mathml">'
+    '<math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow>'
+    '<mn>98897</mn><mi>x</mi><mn>2</mn><msub><mn>1</mn><mn>19</mn></msub>'
+    '<mo>+</mo><mn>2</mn><mi>x</mi><mn>92</mn><msub><mn>3</mn><mn>19</mn></msub>'
+    '</mrow><annotation encoding="application/x-tex"> 98897x21_{19} + 2x923_{19} '
+    '</annotation></semantics></math></span>'
+    '<span aria-hidden="true" class="katex-html">'
+    '<span class="base"><span class="strut" style="height: 0.79em;"></span>'
+    '<span class="mord">98897</span></span></span></span></span> — найдите x.</p>'
+)
+
+
+# ---------- класс B: katex → $LaTeX$ ----------
+
+def test_katex_block_replaced_with_dollar_latex() -> None:
+    res = katex_html_to_latex(_REAL_KATEX)
+    assert res.changed
+    assert "$98897x21_{19} + 2x923_{19}$" in res.cleaned
+    # вся katex-вёрстка снята: ни контейнера, ни inline-style не осталось
+    assert "class=\"katex\"" not in res.cleaned
+    assert "katex-html" not in res.cleaned
+    assert "style=" not in res.cleaned
+    assert len(res.removed) == 1 and res.removed[0][0] == "katex_html"
+
+
+def test_katex_preserves_surrounding_text() -> None:
+    res = katex_html_to_latex(_REAL_KATEX)
+    assert "Операнды записаны в системе счисления" in res.cleaned
+    assert "— найдите x." in res.cleaned
+    # внешняя обёртка <span>…</span> вокруг katex не оставила висящих тегов
+    assert "<span></span>" not in res.cleaned
+
+
+def test_katex_idempotent() -> None:
+    once = katex_html_to_latex(_REAL_KATEX).cleaned
+    twice = katex_html_to_latex(once)
+    assert not twice.changed
+    assert twice.cleaned == once
+
+
+def test_no_katex_is_noop() -> None:
+    plain = "<p>Сколько бит в килобайте?</p>"
+    res = katex_html_to_latex(plain)
+    assert not res.changed and res.cleaned == plain
+
+
+def test_katex_without_annotation_left_intact() -> None:
+    # Без <annotation> исходный LaTeX недоступен — не трогаем (лучше сломанный
+    # рендер, чем потеря выражения).
+    no_annot = '<p>x <span class="katex"><span class="katex-html">2</span></span></p>'
+    res = katex_html_to_latex(no_annot)
+    assert not res.changed
+
+
+# ---------- класс D: знак сравнения ----------
+
+def test_comparison_sign_made_html_safe() -> None:
+    # annotation с сырым `<` (класс D: «f(n)=1 при n<10»)
+    src = (
+        '<p>при <span><span class="katex"><span class="katex-mathml">'
+        '<math><semantics><mrow><mi>n</mi></mrow>'
+        '<annotation encoding="application/x-tex">n<10</annotation>'
+        '</semantics></math></span></span></span></p>'
+    )
+    res = katex_html_to_latex(src)
+    assert res.changed
+    # сырой `<` заменён на KaTeX-эквивалент \lt (рендер тот же, HTML-безопасно)
+    assert r"\lt" in res.cleaned
+    assert "n<10" not in res.cleaned
+
+
+# ---------- класс C: суррогат `**` / `^` ----------
+
+def test_double_star_power_to_sup() -> None:
+    res = surrogate_powers_to_sup("<p>Найдите 9**2025 mod 7.</p>")
+    assert res.changed
+    assert "9<sup>2025</sup>" in res.cleaned
+
+
+def test_caret_power_to_sup() -> None:
+    res = surrogate_powers_to_sup("<p>2^32 битов</p>")
+    assert res.changed
+    assert "2<sup>32</sup>" in res.cleaned
+
+
+def test_python_code_power_protected() -> None:
+    # Внутри <code>/<pre> `**` — оператор Python, не степень ЕГЭ.
+    src = "<p>Оператор:</p><pre>result = base ** exp</pre>"
+    res = surrogate_powers_to_sup(src)
+    assert not res.changed
+    assert "<sup>" not in res.cleaned
+
+
+def test_backtick_inline_code_protected() -> None:
+    # markdown-бэктики — Python-код, не суррогат ЕГЭ (авторские курсы Python).
+    src = "<p>Выполните `print(23**45)` и проверьте `i**3 <= n`.</p>"
+    res = surrogate_powers_to_sup(src)
+    assert not res.changed
+    assert "`print(23**45)`" in res.cleaned
+    assert "<sup>" not in res.cleaned
+
+
+def test_latex_exponent_in_dollars_protected() -> None:
+    # `^` внутри $…$ — это корректный LaTeX-показатель, а НЕ суррогат.
+    # Перевод в <sup> сломал бы формулу (на проде 34 таких задания).
+    src = "<p>Найдите $10^{2024}$ и $2^8$.</p>"
+    res = surrogate_powers_to_sup(src)
+    assert not res.changed
+    assert "<sup>" not in res.cleaned
+    assert "$10^{2024}$" in res.cleaned
+
+
+def test_surrogate_outside_dollars_but_latex_inside() -> None:
+    # Смешанный stem: суррогат вне долларов чиним, LaTeX внутри — нет.
+    src = "<p>вне 3**16, внутри $x^2$</p>"
+    res = surrogate_powers_to_sup(src)
+    assert "3<sup>16</sup>" in res.cleaned
+    assert "$x^2$" in res.cleaned
+
+
+def test_surrogate_idempotent() -> None:
+    once = surrogate_powers_to_sup("<p>9**2025</p>").cleaned
+    twice = surrogate_powers_to_sup(once)
+    assert not twice.changed
+
+
+# ---------- комбинированный конвейер ----------
+
+def test_normalize_math_markup_combines_classes() -> None:
+    src = _REAL_KATEX + "<p>также 3**16</p>"
+    res = normalize_math_markup(src)
+    assert res.changed
+    assert "$98897x21_{19} + 2x923_{19}$" in res.cleaned
+    assert "3<sup>16</sup>" in res.cleaned
+
+
+def test_normalize_math_markup_idempotent() -> None:
+    once = normalize_math_markup(_REAL_KATEX + "<p>3**16</p>").cleaned
+    twice = normalize_math_markup(once)
+    assert not twice.changed
+
+
+def test_empty_input() -> None:
+    assert normalize_math_markup("").cleaned == ""
+    assert not normalize_math_markup("   ").changed
