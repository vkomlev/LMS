@@ -0,0 +1,223 @@
+r"""Нормализация математической разметки stem веб-скрейпа (tsk-398).
+
+Проблема (аудит прод-БД `learn` 2026-07-24, tsk-391 чинил ДАННЫЕ, здесь — ИСТОЧНИК):
+парсеры внешних источников (`decode_contents()`) тащат в stem готовую KaTeX-вёрстку
+чужого сайта — `<span class="katex">…</span>` с десятками вложенных `<span style=…>`.
+Санитайзер CB (`sanitizer.py`) вырезает `<annotation encoding="application/x-tex">`
+(исходный LaTeX внутри katex) и снимает `style`, поэтому в LMS уезжает «голая»
+геометрия KaTeX, а клиент SPW рендерит её сломанной (индекс/степень отдельной строкой).
+
+Три класса дефекта, которые здесь закрываются ДО санитайза:
+
+- **B — KaTeX-вёрстка → `$LaTeX$`.** Весь `<span class="katex">…</span>` заменяется
+  на исходный LaTeX из вложенного `<annotation>`, обёрнутый в `$…$`. SPW рендерит `$…$`
+  штатным react-katex (`KaTeXRender`), минуя санитайзер, — так уже рендерятся сотни
+  заданий. Границы katex-блока считаются БАЛАНСОМ span-тегов, а не жадным regex (внутри
+  десятки вложенных span — жадность схлопнула бы две формулы в одну).
+
+- **C — суррогатная степень `**` / `^`.** `9**2025` (питон) / `9^2025` переводятся в
+  `9<sup>2025</sup>` (тег `sup` в whitelist санитайзера). Реальный Python-код внутри
+  `<code>`/`<pre>` защищён — там `**` это оператор, а не степень ЕГЭ.
+
+- **D — знак сравнения в математике.** Извлечённый из annotation LaTeX может содержать
+  сырой `<` / `>` (напр. `n<10`). Сырой `<` в stem HTML-санитайзер (nh3/DOMPurify) видит
+  как начало тега и съедает `<10` — условие становится неоднозначным ученику. Поэтому
+  внутри выдаваемого `$…$` `<`/`>` заменяются на KaTeX-эквиваленты `\lt`/`\gt`
+  (идентичный рендер, но HTML-безопасно). Правка применяется ТОЛЬКО к LaTeX, который
+  модуль сам извлёк из annotation, — произвольные существующие `$…$` не трогаются
+  (их разбор рискован; их ловит инвариант-детектор на стороне LMS).
+
+Функции чистые (без БД/HTTP), идемпотентные: повторный прогон даёт `changed=False`.
+Порядок в pipeline: сначала `katex_html_to_latex` (снимает вёрстку), затем
+`surrogate_powers_to_sup` (по уже очищенному тексту), оба — ДО `sanitize_html`.
+"""
+from __future__ import annotations
+
+import html as html_mod
+import re
+
+from monolith.external_tasks.normalizer.stem_hygiene import StemCleanResult
+
+# Открывающий тег katex-контейнера. Внешняя обёртка <span>…</span> вокруг него
+# (если есть) прихватывается отдельно, чтобы не оставить висящий пустой span.
+_KATEX_OPEN_RE = re.compile(r'<span class="katex">', re.IGNORECASE)
+_SPAN_TAG_RE = re.compile(r"<(/?)span\b[^>]*>", re.IGNORECASE)
+_ANNOT_RE = re.compile(
+    r'<annotation encoding="application/x-tex">(.*?)</annotation>',
+    re.IGNORECASE | re.DOTALL,
+)
+_TRAILING_WRAP_RE = re.compile(r"<span>\s*$", re.IGNORECASE)
+
+
+def _katex_block_end(html: str, start: int) -> int:
+    """Позиция конца сбалансированного `<span class="katex">…</span>` от `start`.
+
+    Считаем баланс span-тегов: внутри katex-контейнера десятки вложенных span,
+    жадный `.*?</span>` закрыл бы блок на первом же внутреннем `</span>`.
+    """
+    depth = 0
+    i = start
+    n = len(html)
+    while i < n:
+        m = _SPAN_TAG_RE.search(html, i)
+        if not m:
+            return n
+        depth += -1 if m.group(1) else 1
+        i = m.end()
+        if depth == 0:
+            return i
+    return n
+
+
+def _latex_relations_safe(latex: str) -> str:
+    """Сырые `<`/`>` в LaTeX → `\\lt`/`\\gt` (HTML-безопасно, рендер идентичен).
+
+    KaTeX рендерит `\\lt`/`\\gt` ровно как `<`/`>`, но сырой `<` в строке stem
+    HTML-санитайзер съел бы как начало тега (класс D). Уже экранированные формы
+    (`\\lt`, `\\leq`, `<=` внутри команды) не трогаем: заменяется ровно одиночный
+    символ `<`/`>`, а `\\lt`/`\\gt` его не содержат.
+    """
+    latex = latex.replace("<", r"\lt ").replace(">", r"\gt ")
+    # Схлопнуть возможный двойной пробел после подстановки (косметика LaTeX).
+    return re.sub(r"[ ]{2,}", " ", latex)
+
+
+def katex_html_to_latex(raw: str) -> StemCleanResult:
+    """Заменяет KaTeX-вёрстку её LaTeX-исходником в долларах (класс B + D).
+
+    Args:
+        raw: исходный stem (HTML со страницы источника, возможно с katex).
+
+    Returns:
+        StemCleanResult: очищенный HTML, флаг изменения и аудит `removed`
+        (`katex_html` для каждого снятого блока).
+    """
+    if not raw or "class=\"katex\"" not in raw.replace("'", '"'):
+        return StemCleanResult(cleaned=raw or "", changed=False)
+
+    removed: list[tuple[str, str]] = []
+    out: list[str] = []
+    i = 0
+    while True:
+        m = _KATEX_OPEN_RE.search(raw, i)
+        if not m:
+            out.append(raw[i:])
+            break
+        pre = raw[i:m.start()]
+        # Прихватываем внешнюю обёртку <span> перед katex, если она есть.
+        wrap = _TRAILING_WRAP_RE.search(pre)
+        out.append(pre[: wrap.start()] if wrap else pre)
+
+        end = _katex_block_end(raw, m.start())
+        # Съесть закрывающий </span> внешней обёртки, если её открыли.
+        tail = re.match(r"\s*</span>", raw[end:])
+        if wrap and tail:
+            end += tail.end()
+
+        block = raw[m.start():end]
+        annot = _ANNOT_RE.search(block)
+        if annot:
+            latex = _latex_relations_safe(html_mod.unescape(annot.group(1)).strip())
+            out.append(f"${latex}$")
+            removed.append(("katex_html", block))
+        else:
+            # annotation нет — исходный LaTeX недоступен, вёрстку не трогаем
+            # (лучше сломанный рендер, чем потеря выражения).
+            out.append(block)
+        i = end
+
+    cleaned = "".join(out)
+    return StemCleanResult(
+        cleaned=cleaned,
+        changed=cleaned != raw,
+        removed=removed,
+    )
+
+
+# --- Класс C: суррогат `**` / `^` → <sup> ----------------------------------------
+
+_CODE_BLOCK_RE = re.compile(r"<(code|pre)\b.*?</\1>", re.DOTALL | re.IGNORECASE)
+# Инлайн-код в markdown-бэктиках: `print(23**45)`, `i**3 <= n` — тоже Python,
+# не суррогат ЕГЭ (авторские курсы Python пишут код бэктиками, а не <code>).
+_INLINE_CODE_RE = re.compile(r"`[^`]+`")
+# Математика в долларах: там `^`/`**` — это LaTeX (показатель `10^{2024}`), а НЕ
+# суррогат. Защищаем целиком, иначе перевод в <sup> сломал бы формулу.
+_MATH_SPAN_RE = re.compile(r"\$[^$]+\$")
+_POW_STARSTAR_RE = re.compile(
+    r"([0-9A-Za-zА-Яа-яё\)\]])\s*\*\*\s*([0-9A-Za-z]{1,4})\b")
+_POW_CARET_RE = re.compile(
+    r"([0-9A-Za-zА-Яа-яё\)\]])\s*\^\{?([0-9A-Za-z]{1,4})\}?")
+
+
+def surrogate_powers_to_sup(raw: str) -> StemCleanResult:
+    """Питоновскую/markdown-запись степени (`**`/`^`) переводит в `<sup>` (класс C).
+
+    Защищены (НЕ суррогат, не трогаем):
+    - `<code>`/`<pre>` и markdown-бэктики `` `…` `` — там `**` это оператор Python
+      (`print(23**45)`, `i**3 <= n`, `**kwargs`), а не показатель ЕГЭ;
+    - `$…$` — там `^`/`**` это LaTeX-математика (`10^{2024}`), перевод в <sup>
+      сломал бы формулу (найдено на проде: 34 задания с `^` внутри `$…$`).
+
+    Подстрочник `_NN` НЕ трогаем — «Задание 14_13» это номер задания, а не основание
+    системы счисления (ловушка tsk-391); такие случаи правятся точечно.
+
+    Args:
+        raw: исходный stem (HTML).
+
+    Returns:
+        StemCleanResult: очищенный HTML и флаг изменения.
+    """
+    if not raw or ("**" not in raw and "^" not in raw):
+        return StemCleanResult(cleaned=raw or "", changed=False)
+
+    guards: list[str] = []
+
+    def _stash(m: re.Match) -> str:
+        guards.append(m.group(0))
+        return f"\x00G{len(guards) - 1}\x00"
+
+    # Прячем неприкосновенное: математику в долларах, код-блоки и инлайн-бэктики.
+    s = _MATH_SPAN_RE.sub(_stash, raw)
+    s = _CODE_BLOCK_RE.sub(_stash, s)
+    s = _INLINE_CODE_RE.sub(_stash, s)
+    # base ** exp → base<sup>exp</sup>; последний символ основания остаётся слева
+    # (2187**2020 → 2187<sup>2020</sup>).
+    s = _POW_STARSTAR_RE.sub(r"\1<sup>\2</sup>", s)
+    s = _POW_CARET_RE.sub(r"\1<sup>\2</sup>", s)
+
+    for idx, g in enumerate(guards):
+        s = s.replace(f"\x00G{idx}\x00", g)
+
+    return StemCleanResult(cleaned=s, changed=s != raw)
+
+
+def normalize_math_markup(raw: str) -> StemCleanResult:
+    """Полная нормализация мат-разметки stem: katex→LaTeX (B/D) + суррогат (C).
+
+    Порядок важен: сначала снимаем katex-вёрстку (внутри неё `**`/`^` не бывает),
+    затем переводим суррогатную степень по уже очищенному тексту.
+
+    Args:
+        raw: исходный stem (HTML со страницы источника).
+
+    Returns:
+        StemCleanResult: итоговый HTML, объединённый флаг изменения и аудит
+        `removed` (какие katex-блоки сняты).
+    """
+    if not raw or not raw.strip():
+        return StemCleanResult(cleaned=raw or "", changed=False)
+
+    step_b = katex_html_to_latex(raw)
+    step_c = surrogate_powers_to_sup(step_b.cleaned)
+    return StemCleanResult(
+        cleaned=step_c.cleaned,
+        changed=step_c.cleaned != raw,
+        removed=step_b.removed,
+    )
+
+
+__all__ = [
+    "katex_html_to_latex",
+    "surrogate_powers_to_sup",
+    "normalize_math_markup",
+]
