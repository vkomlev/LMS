# LMS Core API — пример .env (Y-1..Y-4 pre-S5).
# Скопируйте в .env и заполните реальными значениями. НЕ коммитьте .env.

# ────────────────────── Core ──────────────────────

# URL подключения к БД (SQLAlchemy AsyncPG)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/Learn

# Список service API-ключей через запятую (без пробелов).
# Используют: TG_LMS bots (poller, teacher dialog), ContentBackbone CLI,
# SPW E2E live spec (Y-4 S5 через /auth/test/issue-session).
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Документация: docs/operations/service-api-key.md
VALID_API_KEYS=replace-with-token-urlsafe-48,optional-second-key

# Уровень логирования: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Environment marker: dev | test | production
# Используется fail-secure security-critical сервисами (Y-3.1 link_token,
# Y-4 pre-S5 test_endpoints_enabled gating).
ENV=dev

# ────────────────────── Y-4 pre-S5: тестовые auth-эндпоинты ──────────────────────

# POST /auth/test/issue-session — bootstrap cookie для E2E spec'ов.
# KEEP FALSE in prod даже если ENV случайно = dev/test.
# Двойной gating: ENV in {"dev","test"} AND TEST_ENDPOINTS_ENABLED=true → endpoint работает.
TEST_ENDPOINTS_ENABLED=false

# Cookie secure flag — True в prod (HTTPS), False в dev (HTTP localhost)
COOKIE_SECURE=false

# ────────────────────── Phase Y-1 auth ──────────────────────

# Resend для magic-link email; пустой → dev-fallback (лог в stdout)
RESEND_API_KEY=
SMTP_FROM=noreply@victor-komlev.ru

# Базовый URL SPW для встраивания в magic-link письма + email-шаблоны Y-4.
# Dev: http://localhost:3000; prod: https://learn.victor-komlev.ru
PUBLIC_BASE_URL=http://localhost:3000

# Секреты для подписи magic-link / session — генерация:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
MAGIC_LINK_SECRET=replace-with-token-urlsafe-48
SESSION_SIGNING_KEY=replace-with-token-urlsafe-48
FERNET_MASTER_KEY=replace-with-fernet-key

# TG initData verification (HMAC от bot_token)
TG_BOT_TOKEN_FOR_INITDATA=

# VK ID 2.0 PKCE
VK_ID_CLIENT_ID=
VK_ID_CLIENT_SECRET=
VK_ID_REDIRECT_URI=

# Redis для rate-limit + session cache + link_token
REDIS_URL=redis://localhost:6379/2

# ────────────────────── CORS ──────────────────────

CORS_ALLOWED_ORIGINS=http://localhost:3000

# ────────────────────── Imports / прочее ──────────────────────

GSHEETS_SPREADSHEET_ID=
GSHEETS_WORKSHEET_NAME=Tasks
GSHEETS_SERVICE_ACCOUNT_JSON=

DEFAULT_POINTS_SHORT_ANSWER=10
PREPEND_INPUT_LINK=true
INPUT_LINK_LABEL=Входные данные

LEARNING_ENGINE_V1=false

MESSAGES_UPLOAD_DIR=uploads/messages
MATERIALS_UPLOAD_DIR=uploads/materials
MAX_ATTACHMENT_SIZE_BYTES=10485760
ATTACHMENT_CHUNK_SIZE=1048576
